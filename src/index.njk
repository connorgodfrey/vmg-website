---
title: Home
layout: layout.njk
description: "VMG Business Advisory, PLLC — corporate and transactional counsel for startups, founders, funds, and investors. Nationwide advisory including SMR nuclear energy."
---

<style>
  /* reduce top whitespace above hero ~75% */
  main { padding-top: 13px !important; }

  /* hero spacing below image ~60% reduction */
  .hero { margin-bottom: 16px; }

  /* two-column card grid on desktop, single column on mobile */
  .pa-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }
  @media (min-width: 640px) {
    .pa-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  .pa-list li {
    border: 1px solid #e0e4e8;
    border-radius: 8px;
    padding: 10px 14px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .pa-list li:hover {
    border-color: #001f3f;
    box-shadow: 0 2px 8px rgba(0,31,63,0.1);
  }
  .pa-list li a {
    text-decoration: none;
    color: #001f3f;
    font-weight: 500;
    font-size: 1rem;
  }

  /* Latest from the Blog cards */
  .home-blog-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .home-blog-card {
    border: 1px solid #e6e6e6;
    border-radius: 10px;
    padding: 12px 14px;
  }
  .home-blog-card h3 {
    margin: 0 0 6px 0;
    font-size: 1.05rem;
  }
  .home-blog-card p {
    margin: 0 0 8px 0;
    line-height: 1.5;
  }
  .home-blog-meta {
    font-size: 0.9rem;
    color: #666;
    margin-bottom: 6px;
  }
</style>

<div class="hero">
  <img src="/assets/lighthouse.jpg" alt="Lighthouse overlooking the sea — a symbol of clear direction in complex matters" style="width: 100%; border-radius: 8px;">
</div>

<h1 style="text-align: center; font-size: 2em; margin-bottom: 6px;">VMG Business Advisory, PLLC</h1>

<p style="text-align: center; font-size: 1.2em; margin-top: 4px;">
  Corporate & Transactional Counsel.<br>
  Practical legal and strategic guidance for businesses, founders, and investors.
</p>

<h2><a href="/practice-areas/" style="text-decoration: none; color: inherit;">Practice Areas</a></h2>

<ul class="pa-list">
  <li><a href="/practice-areas/corporate-governance/" style="color: inherit;">Corporate Governance</a></li>
  <li><a href="/practice-areas/private-placements-securities/" style="color: inherit;">Private Offerings &amp; Securities</a></li>
  <li><a href="/practice-areas/mergers-acquisitions/" style="color: inherit;">Mergers &amp; Acquisitions</a></li>
  <li><a href="/practice-areas/venture-capital-safe-negotiation/" style="color: inherit;">Venture Capital &amp; Startup Financing</a></li>
  <li><a href="/practice-areas/startup-advisory/" style="color: inherit;">Startup Advisory</a></li>
  <li><a href="/practice-areas/business-financial-advisory/" style="color: inherit;">Business &amp; Financial Advisory</a></li>
  <li><a href="/practice-areas/professional-service-entities/" style="color: inherit;">Licensed Professional Firms</a></li>
  <li><a href="/practice-areas/not-for-profit/" style="color: inherit;">Nonprofit Organizations</a></li>
  <li><a href="/practice-areas/nuclear-startup-advisory/" style="color: inherit;">Nuclear/SMR Energy Development</a></li>
  <li><a href="/practice-areas/outside-general-counsel/" style="color: inherit;">Outside General Counsel</a></li>
</ul>

<hr style="margin: 36px 0;">

{% set posts = collections.blog | reverse %}

{% if posts | length > 0 %}
<section>
  <h2 style="margin-bottom: 12px;">Latest from the Blog</h2>

  <div class="home-blog-list">

    {# Post 1 #}
    {% if posts[0] %}
      {% set p = posts[0] %}
      <article class="home-blog-card">
        <h3>
          <a href="{{ p.url }}" style="text-decoration: none; color: inherit;">
            {{ p.data.title }}
          </a>
        </h3>
        <p class="home-blog-meta">
          {{ p.date | date("MMM d, yyyy") }}
        </p>
        {% set img0 = p.templateContent | firstImageSrc %}
        {% if img0 %}
          <a href="{{ p.url }}">
            <img src="{{ img0 }}" alt="{{ p.data.title }}" style="width: 50%; border-radius: 8px; margin-bottom: 6px;">
          </a>
        {% endif %}
        {% if p.data.description %}
          <p>{{ p.data.description }}</p>
        {% endif %}
      </article>
    {% endif %}

