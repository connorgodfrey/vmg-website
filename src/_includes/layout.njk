<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#001f3f">

  {% seoHead title, description, tags, date %}

  <!-- Geo-location for local SEO -->
  <meta name="geo.region" content="US-NY">
  <meta name="geo.placename" content="Buffalo">
  <meta name="geo.position" content="42.8864;-78.8784">
  <meta name="ICBM" content="42.8864, -78.8784">

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/assets/VMGBA.png">
  <link rel="apple-touch-icon" href="/assets/VMGBA.png">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">

  <!-- Global styles -->
  <link rel="stylesheet" href="/assets/styles/main.css">
  <style>
    body {
      font-family: system-ui, -apple-system, sans-serif;
      font-size: 17px;
      line-height: 1.65;
      color: #1a1a1a;
      margin: 0;
      padding: 0;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: 'Lora', Georgia, serif;
      line-height: 1.25;
    }
    header {
      background-color: #001f3f;
      color: white;
      padding: 10px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    #main-nav a {
      margin: 0 15px;
      text-decoration: none;
      color: white;
      font-family: 'Lora', Georgia, serif;
      font-weight: 600;
      white-space: nowrap;
    }
    #main-nav a:hover {
      text-decoration: underline;
    }

    /* Hamburger button — hidden on desktop */
    .nav-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 6px;
    }
    .nav-toggle span {
      display: block;
      width: 22px;
      height: 2px;
      background: white;
    }

    @media (max-width: 640px) {
      .nav-toggle {
        display: flex;
      }
      #main-nav {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #001f3f;
        flex-direction: column;
        padding: 8px 20px 16px;
        z-index: 999;
        border-top: 1px solid rgba(255,255,255,0.15);
      }
      #main-nav.open {
        display: flex;
      }
      #main-nav a {
        margin: 0;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        font-size: 15px;
      }
      #main-nav a:last-child {
        border-bottom: none;
      }
    }

    main {
      max-width: 900px;
      margin: auto;
      padding: 30px 20px 40px 20px;
    }

    /* Practice area detail pages — accent bar on H2 sections */
    .pa-detail h2 {
      border-left: 3px solid #001f3f;
      padding-left: 0.7rem;
      margin-top: 2.25rem;
    }

    /* Footer */
    .site-footer {
      background: #f7f8fa;
      border-top: 1px solid #e4e4e4;
      margin-top: 60px;
    }
    .site-footer-inner {
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 20px 28px;
    }
    .site-footer-top {
      display: flex;
      flex-wrap: wrap;
      gap: 32px;
      justify-content: space-between;
      margin-bottom: 28px;
    }
    .site-footer-brand strong {
      font-family: 'Lora', Georgia, serif;
      font-size: 1rem;
      display: block;
      margin-bottom: 8px;
      color: #1a1a1a;
    }
    .site-footer-brand a {
      display: block;
      color: #444;
      text-decoration: none;
      margin-bottom: 4px;
      font-size: 0.95rem;
    }
    .site-footer-brand a:hover { text-decoration: underline; }
    .site-footer-nav {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .site-footer-nav a {
      color: #444;
      text-decoration: none;
      font-size: 0.95rem;
    }
    .site-footer-nav a:hover { text-decoration: underline; }
    .site-footer-bottom {
      border-top: 1px solid #e4e4e4;
      padding-top: 18px;
      font-size: 0.8rem;
      color: #888;
    }
    .site-footer-bottom p { margin: 0 0 6px; }
    .site-footer-bottom p:last-child { margin: 0; }
  </style>

<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-FD1FZLXSRJ"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-FD1FZLXSRJ');
</script>

</head>

<body>

<header>
  <div>
    <a href="/"><img src="/assets/logo2.png" alt="VMG Business Advisory PLLC logo" style="height: 95px;"></a>
  </div>
  <button class="nav-toggle" id="nav-toggle" aria-label="Open navigation" aria-expanded="false" aria-controls="main-nav">
    <span></span><span></span><span></span>
  </button>
  <nav id="main-nav">
    <a href="/about/">About</a>
    <a href="/practice-areas/">Practice Areas</a>
    <a href="/contact/">Contact</a>
    <a href="/blog/">Blog</a>
    <a href="/resources/">Resources</a>
  </nav>
</header>

<main class="{% if '/practice-areas/' in page.url and page.url != '/practice-areas/' %}pa-detail{% endif %}">
  {{ content | safe }}
</main>

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-top">
      <div class="site-footer-brand">
        <strong>VMG Business Advisory, PLLC</strong>
        <a href="/buffalo-corporate-attorney/">Buffalo, NY</a>
        <a href="mailto:connor@vmgba.com">connor@vmgba.com</a>
        <a href="tel:+17164252328">716-425-2328</a>
      </div>
    </div>
    <div class="site-footer-bottom">
      <p>Admitted to the New York State Bar &mdash; Practicing since 2021</p>
      <p>The content on this site is provided for informational purposes only and does not constitute legal advice. Viewing this site or contacting VMG Business Advisory, PLLC does not create an attorney-client relationship.</p>
      <p>&copy; {% year %} VMG Business Advisory, PLLC. All rights reserved.</p>
    </div>
  </div>
</footer>

{% set metaDesc = description or "VMG Business Advisory, PLLC \u2014 corporate, transactional, and SMR nuclear startup advisory services nationwide." %}

<!-- Structured Data / Schema.org -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LegalService",
      "@id": "https://vmgba.com/#organization",
      "name": "VMG Business Advisory, PLLC",
      "alternateName": "VMG BA",
      "url": "https://vmgba.com",
      "logo": "https://vmgba.com/assets/logo2.png",
      "image": "https://vmgba.com/assets/logo2.png",
      "founder": {
        "@type": "Person",
        "@id": "https://vmgba.com/about/#person",
        "name": "Connor T. Godfrey",
        "jobTitle": "Attorney",
        "alumniOf": [
          { "@type": "CollegeOrUniversity", "name": "Fordham University Gabelli School of Business" },
          { "@type": "CollegeOrUniversity", "name": "University at Buffalo School of Law" }
        ]
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Buffalo",
        "addressRegion": "NY",
        "addressCountry": "US"
      },
      "telephone": "+17164252328",
      "email": "connor@vmgba.com",
      "areaServed": "US",
      "description": "VMG Business Advisory, PLLC provides corporate, transactional, and SMR nuclear startup advisory services nationwide. Founded by Connor T. Godfrey, a New York-barred attorney with a finance background.",
      "knowsAbout": [
        "Corporate Governance",
        "Startup Financing",
        "SAFE Agreements",
        "Venture Capital",
        "Small Modular Reactor (SMR) Nuclear Energy",
        "Mergers and Acquisitions",
        "Private Placements",
        "Non-Disclosure Agreements",
        "Foreign Business Expansion to the US",
        "Equity Crowdfunding"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://vmgba.com/#website",
      "url": "https://vmgba.com",
      "name": "VMG Business Advisory, PLLC",
      "publisher": { "@id": "https://vmgba.com/#organization" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://vmgba.com/"
        }{% if page.url != "/" %},{
          "@type": "ListItem",
          "position": 2,
          "name": "{{ title }}",
          "item": "https://vmgba.com{{ page.url }}"
        }{% endif %}
      ]
    }
  ]
}
</script>

{% if tags and "blog" in tags %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title | replace('"', '"') }}",
  "description": "{{ metaDesc | replace('"', '"') }}",
  "datePublished": "{{ date | date('yyyy-MM-dd') }}",
  "author": {
    "@type": "Person",
    "name": "Connor T. Godfrey",
    "@id": "https://vmgba.com/about/#person"
  },
  "publisher": { "@id": "https://vmgba.com/#organization" },
  "url": "https://vmgba.com{{ page.url }}",
  "mainEntityOfPage": "https://vmgba.com{{ page.url }}"
}
</script>
{% endif %}

{% if pageSchema %}
{{ pageSchema | safe }}
{% endif %}

<script>
  const navToggle = document.getElementById('nav-toggle');
  const mainNav   = document.getElementById('main-nav');
  if (navToggle && mainNav) {
    navToggle.addEventListener('click', function () {
      const isOpen = mainNav.classList.toggle('open');
      navToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      navToggle.setAttribute('aria-label', isOpen ? 'Close navigation' : 'Open navigation');
    });
  }
</script>

</body>
</html>
